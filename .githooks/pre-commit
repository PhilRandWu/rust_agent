#!/bin/sh
set -e

# ----- Rust backend -----
cd "$(git rev-parse --show-toplevel)/backend"

echo "==> cargo fmt"
cargo fmt --all -- --check

echo "==> cargo test"
cargo test

echo "==> cargo check"
cargo check

# ----- Frontend -----
cd "$(git rev-parse --show-toplevel)/frontend"

echo "==> pnpm format:check"
pnpm format:check

echo "==> git diff --check"
git diff --check
